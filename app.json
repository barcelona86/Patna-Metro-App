{
  "expo": {
    "name": "Patna Metro",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B3D91"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.rachitsharma.metroapp",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B3D91"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./withAndroidVoiceFix.js",
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow mobile to access your microphone for voice input.",
          "speechRecognitionPermission": "Allow mobile to securely recognize user speech."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "23c1c966-9b46-49e0-8517-c41d40062995"
      }
    }
  }
}